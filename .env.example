# --- Database (local Docker Postgres, see docker-compose.yml) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yourmapevent"

# --- Better Auth ---
# "memory": auth data (users/orgs/sessions) lives in-process and resets on restart.
#           A dev admin + demo team are auto-seeded on boot (see src/instrumentation.ts).
# "postgres": persist auth in the same Postgres DB via Prisma.
#           Requires the Better Auth models in schema.prisma (npx @better-auth/cli generate) + migrate.
AUTH_STORAGE="memory"
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional; social login button appears only when both are set) ---
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- UploadThing (optional; without a token the UI falls back to plain image-URL inputs) ---
UPLOADTHING_TOKEN=""
